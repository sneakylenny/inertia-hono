{
  "name": "playground",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,green \"bun run dev:server\" \"bun run dev:vite\"",
    "dev:server": "bun --watch --no-clear-screen run src/index.ts",
    "dev:vite": "vite",
    "start": "NODE_ENV=production bun run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:client": "vite build",
    "build": "vite build"
  },
  "dependencies": {
    "@hono/standard-validator": "^0.1.5",
    "@inertiajs/vue3": "^3.0.0",
    "@vueuse/core": "^14.2.1",
    "hono": "^4.7.4",
    "@sneakylenny/inertia-hono": "workspace:*",
    "valibot": "^1.3.1",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/bun": "latest",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "daisyui": "^5.5.19",
    "happy-dom": "^17.4.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.2",
    "vite": "5.4.14",
    "vitest": "^3.0.9"
  }
}
