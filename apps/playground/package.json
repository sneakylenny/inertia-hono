{
  "name": "playground",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,green \"bun run dev:server\" \"bun run dev:vite\"",
    "dev:server": "bun --watch run src/index.ts",
    "dev:vite": "vite",
    "start": "bun run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:client": "vite build"
  },
  "dependencies": {
    "@inertiajs/vue3": "^2.0.8",
    "hono": "^4.7.4",
    "inertia-hono": "workspace:*",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@vitejs/plugin-vue": "^5.2.1",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "happy-dom": "^17.4.4",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.9"
  }
}
