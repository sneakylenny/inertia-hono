{
  "name": "inertia-server",
  "version": "0.1.0",
  "description": "Framework-agnostic Inertia.js v3 protocol helpers for JavaScript servers",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts --outdir ./dist --format esm --sourcemap --target node && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepublishOnly": "bun run build"
  },
  "keywords": ["inertia", "inertiajs", "protocol"],
  "license": "MIT",
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
