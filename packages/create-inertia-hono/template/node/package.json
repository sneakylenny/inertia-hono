{
  "name": "my-inertia-app",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,vite -c blue,green \"npm run dev:server\" \"npm run dev:vite\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:vite": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production tsx src/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@inertiajs/vue3": "^3.0.0",
    "hono": "^4.7.0",
    "inertia-hono": "^0.1.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "concurrently": "^9.1.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vite": "^5.4.0"
  }
}
