{
  "name": "inertia-hono-monorepo",
  "private": true,
  "workspaces": ["packages/*", "apps/*"],
  "scripts": {
    "ci": "bun install --frozen-lockfile && moon run :build && moon run :test && moon run :lint && bunx eslint scripts --max-warnings 0",
    "build": "moon run :build",
    "test": "moon run :test",
    "dev": "moon run playground:dev",
    "lint": "eslint packages apps scripts --max-warnings 0",
    "lint:fix": "eslint packages apps --fix",
    "lint:inertia-server": "eslint packages/inertia-server --max-warnings 0",
    "lint:inertia-hono": "eslint packages/inertia-hono --max-warnings 0",
    "lint:playground": "eslint apps/playground --max-warnings 0",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "postinstall": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-push": "node scripts/pre-push.mjs"
  },
  "type": "module",
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "simple-git-hooks": "^2.13.1",
    "@types/bun": "latest",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "typescript-eslint": "^8.57.1",
    "vue-eslint-parser": "^10.4.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0"
  }
}
